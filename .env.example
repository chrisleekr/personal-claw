# Database
DATABASE_URL=postgresql://claw:claw_dev@localhost:5432/personalclaw

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# Slack (optional — required if using Slack as a channel)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Discord (optional — required if using Discord as a channel)
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=

# LLM Providers
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
# AWS Bedrock (alternative LLM provider)
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
AWS_BEDROCK_PROFILE=
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=

# Embeddings (openai or bedrock — bedrock reuses AWS creds above)
EMBEDDING_PROVIDER=openai
# Optional: override the default embedding model per provider
# Defaults: text-embedding-3-small (openai), amazon.titan-embed-text-v2:0 (bedrock)
# EMBEDDING_MODEL=
# OpenAI (required when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key

# Auth
AUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_URL=http://localhost:3000

# API authentication (shared secret between web app and API server)
# Required in production (min 32 chars). Generate with: openssl rand -base64 32
API_SECRET=generate-with-openssl-rand-base64-32

# App
API_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL is only used for the WebSocket config-updates connection.
# REST API calls are proxied through /api/proxy to keep API_SECRET server-side.
NEXT_PUBLIC_API_URL=http://localhost:4000
